generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "windows"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id
  username  String   @unique
  role      String
  isActive  Boolean  @default(true)
  updatedAt DateTime @updatedAt

  @@map("users")
}

model PriceState {
  unidade      String   @id
  valorAtual   Float    @default(0)
  modoFesta    Boolean  @default(false)
  partyBanners String   @default("[]") @db.VarChar(5000)
  valorFuturo  Float?
  textoFuturo  String?  @default("???")
  valorPassado Float?
  aviso1       String?
  aviso2       String?
  aviso3       String?
  aviso4       String?
  updatedAt    DateTime @updatedAt

  @@map("price_states")
}

model PriceDefault {
  id         String   @id @default(uuid())
  unidade    String
  tipoDia    String
  periodo    String
  qtdPessoas Int
  valor      Float
  updatedAt  DateTime @updatedAt

  @@map("price_defaults")
}

model PriceCategoryMedia {
  id             String   @id @default(uuid())
  unidade        String
  qtdPessoas     Int
  titulo         String?
  mediaUrl       String?
  avisoCategoria String?
  updatedAt      DateTime @updatedAt

  @@map("price_category_media")
}

model Holiday {
  id          String   @id @default(uuid())
  unidade     String
  nome        String
  dataFeriado String
  createdAt   DateTime @default(now())

  @@map("holidays")
}

model Promotion {
  id         String   @id @default(uuid())
  unidade    String
  imageUrl   String
  diasAtivos String   @default("[]")
  createdAt  DateTime @default(now())

  @@map("promotions")
}

model ScoreboardConfig {
  id            String   @id @default(uuid())
  unidade       String   @unique
  titulo        String   @default("")
  layout        String   @default("landscape")
  isActive      Boolean  @default(false)
  capacidadeMax Int      @default(230)
  opcoes        Json     @default("[]")
  updatedAt     DateTime @updatedAt

  @@map("scoreboard_configs")
}

model ScoreboardPreset {
  id            String   @id @default(uuid())
  unidade       String
  titulo_preset String
  titulo_placar String   @default("")
  layout        String   @default("landscape")
  opcoes        Json     @default("[]")
  createdAt     DateTime @default(now())

  @@index([unidade])
  @@map("scoreboard_presets")
}

model ScoreboardVote {
  id               String    @id @default(uuid())
  unidade          String
  cliente_id       String?
  cliente_nome     String?
  cliente_pulseira String?
  option_index     Int?
  status           String    @default("DENTRO")
  expires_at       DateTime?
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  @@index([unidade, created_at])
  @@map("scoreboard_votes")
}

model ScoreboardPhrase {
  id          String   @id @default(uuid())
  unidade     String
  tipo        String   @default("movement")
  porcentagem Int?
  texto       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([unidade, tipo])
  @@map("scoreboard_phrases")
}